{
  "name": "myahlyns",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && next dev",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "services:up": "sudo docker compose -f infra/compose.yaml up -d",
    "services:down": "sudo docker compose -f infra/compose.yaml down",
    "migration:create": "dotenv -e .env.development node-pg-migrate -m infra/migrations create",
    "migration:up": "dotenv -e .env.development node-pg-migrate -m infra/migrations up"
  },
  "author": "Jonathan",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "next": "^13.1.6",
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4"
  }
}
